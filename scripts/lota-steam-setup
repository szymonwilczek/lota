#!/bin/bash
# SPDX-License-Identifier: MIT
#
# lota-steam-setup -- Configure Steam for LOTA integration
#
# Sets up the LOTA agent socket to be accessible from inside
# Steam Runtime pressure-vessel containers (soldier, sniper, etc.)
# and configures the LD_PRELOAD hook for automatic loading.
#
# What this script does:
#   1. Creates $XDG_RUNTIME_DIR/lota/ with correct permissions
#   2. Verifies the LOTA agent is reachable from the container path
#   3. Prints Steam launch option instructions
#
# Usage:
#   lota-steam-setup             Run setup checks
#   lota-steam-setup --verify    Verify existing setup only
#   lota-steam-setup --help      Show help
#
# Copyright (C) 2026 Szymon Wilczek

set -euo pipefail

LOTA_GROUP="lota"
SOCKET_NAME="lota.sock"
PRIMARY_SOCKET="/run/lota/${SOCKET_NAME}"
HOOK_LIB="liblota_wine_hook.so"
LOTA_CONF="/etc/lota/lota.conf"

if [[ -t 1 ]]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[0;33m'
    BLUE='\033[0;34m'
    NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' NC=''
fi

info()  { echo -e "${BLUE}[INFO]${NC} $*"; }
ok()    { echo -e "${GREEN}[OK]${NC}   $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $*"; }
fail()  { echo -e "${RED}[FAIL]${NC} $*"; }

usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Configure Steam Runtime integration for LOTA.

Options:
  --verify                    Only check existing setup, do not
                              modify anything
  --install-systemd-dropin    Install the systemd drop-in that pins
                              XDG_RUNTIME_DIR=/run/user/<uid> for
                              lota-agent.service, so the agent's
                              container-aware secondary listener
                              (\$XDG_RUNTIME_DIR/lota/lota.sock)
                              comes up under the operator's
                              runtime dir on boot. Requires root.
                              Single-operator hosts only; for
                              multiple operators use --register-uid.
  --register-uid              Append container_listener_uid = \$SUDO_UID
                              to ${LOTA_CONF} and restart lota-agent so
                              every configured operator UID gets its
                              own /run/user/<uid>/lota/lota.sock
                              listener. Supersedes the drop-in on
                              multi-user hosts. Requires root.
  --help                      Show this help message

Environment:
  XDG_RUNTIME_DIR   Base directory for user runtime files (required)
EOF
}

check_xdg_runtime_dir() {
    if [[ -z "${XDG_RUNTIME_DIR:-}" ]]; then
        fail "XDG_RUNTIME_DIR is not set"
        echo "  This variable is required for container-aware IPC."
        echo "  It is normally set by systemd-logind or elogind."
        return 1
    fi

    if [[ ! -d "$XDG_RUNTIME_DIR" ]]; then
        fail "XDG_RUNTIME_DIR=$XDG_RUNTIME_DIR does not exist"
        return 1
    fi

    ok "XDG_RUNTIME_DIR=$XDG_RUNTIME_DIR"
    return 0
}

check_agent_running() {
    if [[ -S "$PRIMARY_SOCKET" ]]; then
        ok "LOTA agent socket: $PRIMARY_SOCKET"
        return 0
    fi

    warn "LOTA agent socket not found at $PRIMARY_SOCKET"
    echo "  The agent may not be running.  Start it with:"
    echo "    sudo lota-agent --daemon"
    return 1
}

check_lota_group() {
    if getent group "$LOTA_GROUP" >/dev/null 2>&1; then
        ok "Group '$LOTA_GROUP' exists"
    else
        warn "Group '$LOTA_GROUP' does not exist"
        echo "  Create it with: sudo groupadd $LOTA_GROUP"
        echo "  Add your user:  sudo usermod -aG $LOTA_GROUP \$USER"
        return 1
    fi

    if id -nG | grep -qw "$LOTA_GROUP"; then
        ok "Current user is a member of group '$LOTA_GROUP'"
    else
        warn "Current user is not a member of '$LOTA_GROUP'"
        echo "  Add with: sudo usermod -aG $LOTA_GROUP $(whoami)"
        echo "  Then log out and back in."
        return 1
    fi

    return 0
}

check_hook_library() {
    local found=""

    for candidate in \
        /usr/lib64/${HOOK_LIB} \
        /usr/lib/${HOOK_LIB} \
        /usr/local/lib64/${HOOK_LIB} \
        /usr/local/lib/${HOOK_LIB}; do
        if [[ -f "$candidate" ]]; then
            found="$candidate"
            break
        fi
    done

    if [[ -n "$found" ]]; then
        ok "Hook library found: $found"
    else
        warn "Hook library ($HOOK_LIB) not found in standard paths"
        echo "  Install with: sudo make install"
    fi
}

setup_container_socket_dir() {
    local dir="${XDG_RUNTIME_DIR}/lota"

    if [[ -d "$dir" ]]; then
        ok "Container socket directory exists: $dir"
        return 0
    fi

    info "Creating container socket directory: $dir"
    mkdir -p "$dir"
    chmod 0750 "$dir"

    # set group if possible
    if getent group "$LOTA_GROUP" >/dev/null 2>&1; then
        chgrp "$LOTA_GROUP" "$dir" 2>/dev/null || true
    fi

    ok "Created: $dir"
}

check_container_socket() {
    local container_socket="${XDG_RUNTIME_DIR}/lota/${SOCKET_NAME}"

    if [[ -S "$container_socket" ]]; then
        ok "Container socket: $container_socket"
        return 0
    fi

    warn "Container socket not found: $container_socket"
    echo "  The LOTA agent needs to be (re)started to create this socket."
    echo "  It will automatically create an extra listener at this path."
    return 1
}

verify_only=false
install_dropin=false
register_uid=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --verify)
            verify_only=true
            shift
            ;;
        --install-systemd-dropin)
            install_dropin=true
            shift
            ;;
        --register-uid)
            register_uid=true
            shift
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        *)
            echo "Unknown option: $1" >&2
            usage >&2
            exit 1
            ;;
    esac
done

# install_systemd_dropin: lays down the XDG_RUNTIME_DIR override for
# lota-agent.service so the agent's container-aware secondary
# listener is created on boot under the operator's /run/user/<uid>.
# Single-valued by design; multi-user hosts have to pick the user
# that drives Steam.
install_systemd_dropin() {
    local uid dropin_dir dropin

    # Need root to write under /etc/systemd/system. The operator UID
    # is recovered from $SUDO_UID (sudo sets it) so the drop-in
    # cannot accidentally pin XDG_RUNTIME_DIR to /run/user/0 when
    # the caller forgot to wrap with sudo from their own session.
    if [[ $EUID -ne 0 ]]; then
        fail "--install-systemd-dropin must run as root (try: sudo $(basename "$0") --install-systemd-dropin)"
        return 1
    fi
    if [[ -z "${SUDO_UID:-}" ]]; then
        fail "could not determine the operator UID"
        fail "invoke as: sudo $(basename "$0") --install-systemd-dropin"
        fail "(direct 'su -' / login as root strips \$SUDO_UID and is not supported)"
        return 1
    fi

    uid="$SUDO_UID"
    case "$uid" in
        ''|*[!0-9]*)
            fail "SUDO_UID=${SUDO_UID} is not a positive integer"
            return 1
            ;;
    esac
    if [[ "$uid" -eq 0 ]]; then
        fail "SUDO_UID=0; rerun from a non-root login shell"
        return 1
    fi

    dropin_dir="/etc/systemd/system/lota-agent.service.d"
    dropin="${dropin_dir}/10-xdg-runtime.conf"

    info "Installing drop-in: ${dropin}"
    mkdir -p "$dropin_dir"
    cat >"$dropin" <<EOF
# SPDX-License-Identifier: MIT
# Generated by lota-steam-setup --install-systemd-dropin.
# See systemd/lota-agent.service.d/10-xdg-runtime.conf.example
# in the source tree for the rationale.

[Service]
Environment=XDG_RUNTIME_DIR=/run/user/${uid}
EOF
    chmod 0644 "$dropin"

    systemctl daemon-reload
    if systemctl is-active --quiet lota-agent.socket; then
        info "Restarting lota-agent.socket to pick up the drop-in"
        systemctl restart lota-agent.socket
    fi
    ok "drop-in installed for uid=${uid}"
}

if $install_dropin; then
    install_systemd_dropin || exit 1
    echo ""
    echo "Drop-in active. From the operator account run:"
    echo "  lota-steam-setup --verify"
    echo "to confirm the new /run/user/${SUDO_UID}/lota/lota.sock listener,"
    echo "then paste the printed Steam launch options into the game's"
    echo "Properties -> General -> Launch options field."
    exit 0
fi

# register_container_listener_uid: appends container_listener_uid =
# $SUDO_UID to /etc/lota/lota.conf so the agent creates an extra
# /run/user/<uid>/lota/lota.sock listener for every configured
# operator. Multi-user superset of --install-systemd-dropin: the
# config knob accepts up to LOTA_CONFIG_MAX_CONTAINER_LISTENERS
# entries, while the drop-in can only pin one XDG_RUNTIME_DIR.
register_container_listener_uid() {
    local uid line

    if [[ $EUID -ne 0 ]]; then
        fail "--register-uid must run as root (try: sudo $(basename "$0") --register-uid)"
        return 1
    fi
    if [[ -z "${SUDO_UID:-}" ]]; then
        fail "could not determine the operator UID"
        fail "invoke as: sudo $(basename "$0") --register-uid"
        fail "(direct 'su -' / login as root strips \$SUDO_UID and is not supported)"
        return 1
    fi

    uid="$SUDO_UID"
    case "$uid" in
        ''|*[!0-9]*)
            fail "SUDO_UID=${SUDO_UID} is not a positive integer"
            return 1
            ;;
    esac
    if [[ "$uid" -eq 0 ]]; then
        fail "SUDO_UID=0; rerun from a non-root login shell"
        return 1
    fi

    if [[ ! -f "$LOTA_CONF" ]]; then
        fail "$LOTA_CONF does not exist; install LOTA before --register-uid"
        return 1
    fi

    line="container_listener_uid = ${uid}"
    if grep -Eq "^[[:space:]]*container_listener_uid[[:space:]]*=[[:space:]]*${uid}[[:space:]]*$" "$LOTA_CONF"; then
        ok "uid=${uid} already registered in ${LOTA_CONF}"
    else
        info "Appending '${line}' to ${LOTA_CONF}"
        printf '\n# Added by lota-steam-setup --register-uid\n%s\n' \
            "$line" >>"$LOTA_CONF"
        ok "uid=${uid} registered in ${LOTA_CONF}"
    fi

    if systemctl is-active --quiet lota-agent.service; then
        info "Restarting lota-agent.service to pick up the new UID"
        systemctl restart lota-agent.service
    fi
}

if $register_uid; then
    register_container_listener_uid || exit 1
    echo ""
    echo "From the operator account run:"
    echo "  lota-steam-setup --verify"
    echo "to confirm /run/user/${SUDO_UID}/lota/lota.sock is live,"
    echo "then paste the printed Steam launch options into the game's"
    echo "Properties -> General -> Launch options field."
    exit 0
fi

echo "=== LOTA Steam Runtime Integration Setup ==="
echo ""

errors=0

check_xdg_runtime_dir || errors=$((errors + 1))
check_agent_running   || errors=$((errors + 1))
check_lota_group      || errors=$((errors + 1))
check_hook_library

echo ""

if ! $verify_only; then
    info "Setting up container-accessible socket directory..."
    setup_container_socket_dir || errors=$((errors + 1))
fi

check_container_socket || errors=$((errors + 1))

echo ""
echo "=== Steam Launch Options ==="
echo ""
echo "  For games launched through Steam's pressure-vessel container"
echo "  (any Proton title and most native Linux titles on Steam),"
echo "  the LOTA socket must be bind-mounted into the container and"
echo "  the hook must be pointed at the operator's user-runtime"
echo "  listener.  Paste this string into the game's Properties ->"
echo "  General -> Launch options:"
echo ""
echo "    PRESSURE_VESSEL_FILESYSTEMS_RW=${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/lota \\"
echo "    LOTA_HOOK_SOCKET=${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/lota/lota.sock \\"
echo "    LOTA_HOOK_LOG_LEVEL=info \\"
echo "    lota-proton-hook %command%"
echo ""
echo "  Paste on a single line; the line breaks above are for"
echo "  readability only."
echo ""
echo "  For a host-side launch outside the pressure-vessel"
echo "  container (a native binary you run directly):"
echo ""
echo "    LOTA_HOOK_LOG_LEVEL=info LD_PRELOAD=${HOOK_LIB} %command%"
echo ""

if [[ $errors -gt 0 ]]; then
    echo ""
    warn "$errors issue(s) detected.  See warnings above."
    exit 1
fi

ok "All checks passed.  LOTA Steam integration is ready."

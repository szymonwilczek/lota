# SPDX-License-Identifier: GPL-2.0-only
#
# LOTA SELinux policy - type enforcement
#

policy_module(lota, 0.1.0)

#
# Tunables
#

## <desc>
## <p>Allow network access for remote attestation.</p>
## </desc>
gen_tunable(lota_network_attest, true)

## <desc>
## <p>Allow BPF program loading.</p>
## </desc>
gen_tunable(lota_bpf_load, true)

## <desc>
## <p>Allow interaction with module loading subsystem.</p>
## </desc>
gen_tunable(lota_module_enforce, false)

#
# Type declarations
#

type lota_agent_t;
type lota_agent_exec_t;
init_daemon_domain(lota_agent_t, lota_agent_exec_t)

#
# Packaged lota-agent.service sets enough hardening directives
# that systemd implicitly applies NoNewPrivileges=yes before exec.
# Under NNP a SELinux domain transition is refused unless the source
# domain holds process2:{ nnp_transition nosuid_transition } against
# the target -- without this, init_t cannot enter lota_agent_t and
# the daemon runs (and is denied lota_var_t / lota_tpm_device_t access)
# under init_t's context.
#
allow init_t lota_agent_t:process2 { nnp_transition nosuid_transition };

#
# /run/lota -- socket-activation runtime dir owned by systemd
# (init_t) on RuntimeDirectory=lota creation, and managed by
# lota_agent_t for the agent's witness files under /var/lib/lota.
# files_pid_file() assigns the pid_file attribute that systemd
# already has cascading manage rights on for socket activation
# (dir create, sock_file bind, rmdir on unit stop)
#
type lota_var_t;
files_pid_file(lota_var_t)

type lota_etc_t;
files_config_file(lota_etc_t)

type lota_bpf_t;
files_type(lota_bpf_t)

type lota_log_t;
logging_log_file(lota_log_t)

type lota_tmp_t;
files_tmp_file(lota_tmp_t)

type lota_port_t;
corenet_port(lota_port_t)

#
# Dedicated TPM character-device type.
#
# TPM 2.0 PC Client Platform TPM Profile p3.3 leaves PCR8-15
# (including PCR14, used by lota-agent's boot commitment) auth-free
# and Locality-0 writable. The TPM exposes no on-chip mechanism that
# could gate the extend operation, so the only enforceable barrier
# against a local-root attacker touching PCR14 before lota-agent
# reaches self_measure() lives at the MAC layer.
#
# The shipped udev rule (configs/udev/99-lota-tpm.rules) relabels
# /dev/tpm[0-9]* and /dev/tpmrm[0-9]* with lota_tpm_device_t at
# device-add time. This module is the only policy that allows rw on
# the type and grants it only to lota_agent_t. Stock refpolicy
# interfaces such as dev_rw_tpm() bind to the generic tpm_device_t
# label and therefore no longer apply once the rule has run;
# even an unconfined_t domain loses /dev/tpm* access under SELinux
# enforcing.
#
type lota_tpm_device_t;
dev_node(lota_tpm_device_t)

#
# lota_agent_t policy
#

allow lota_agent_t self:capability { dac_override dac_read_search sys_admin sys_rawio ipc_lock };
allow lota_agent_t self:capability2 { bpf perfmon };
allow lota_agent_t self:process { signal signull setcap setrlimit };
allow lota_agent_t self:fifo_file rw_fifo_file_perms;
allow lota_agent_t self:unix_stream_socket create_stream_socket_perms;
allow lota_agent_t self:unix_dgram_socket create_socket_perms;

# /etc/lota - read only
allow lota_agent_t lota_etc_t:dir list_dir_perms;
allow lota_agent_t lota_etc_t:file read_file_perms;

# /var/lib/lota - read/write
allow lota_agent_t lota_var_t:dir manage_dir_perms;
allow lota_agent_t lota_var_t:file manage_file_perms;

# /usr/lib/lota/*.bpf.o
allow lota_agent_t lota_bpf_t:dir list_dir_perms;
allow lota_agent_t lota_bpf_t:file { read_file_perms execute map };

# /var/log/lota
allow lota_agent_t lota_log_t:dir { create_dir_perms add_entry_dir_perms };
allow lota_agent_t lota_log_t:file { create_file_perms append_file_perms };
logging_log_filetrans(lota_agent_t, lota_log_t, file)

# /tmp/lota
allow lota_agent_t lota_tmp_t:dir manage_dir_perms;
allow lota_agent_t lota_tmp_t:file manage_file_perms;
files_tmp_filetrans(lota_agent_t, lota_tmp_t, { file dir })

#
# Hardware access
#

# /dev/tpm[0-9]*, /dev/tpmrm[0-9]* (relabelled by udev to
# lota_tpm_device_t at device-add time)
allow lota_agent_t lota_tpm_device_t:chr_file rw_chr_file_perms;

# Bootstrap fallback: on systems where the udev rule has not yet
# loaded (early initramfs hand-off, hostile relabel, ...) lota-agent
# still needs read+open on the stock tpm_device_t label so the
# operator can recover. The verifier path detects the missing label
# at attestation time via the agent's clock-state attribution
# (src/agent/tpm.c::tpm_extend_boot_commitment) and refuses to
# attest until the udev relabel has run.
dev_rw_tpm(lota_agent_t)

dev_read_raw_memory(lota_agent_t)

# /dev/urandom
dev_read_urand(lota_agent_t)
dev_read_rand(lota_agent_t)

#
# BPF subsystem
#

fs_manage_bpf_files(lota_agent_t)
fs_manage_bpf_dirs(lota_agent_t)
kernel_read_system_state(lota_agent_t)

tunable_policy(`lota_bpf_load',`
        allow lota_agent_t self:bpf { map_create map_read map_write prog_load prog_run };
        allow lota_agent_t self:perf_event { open read write };
')

#
# System state reads
#

# /proc
domain_read_all_domains_state(lota_agent_t)
kernel_read_proc_symlinks(lota_agent_t)

# /proc/kallsyms. bpf_loader::resolve_kernel_symbol() reads it to pin
# sig_enforce and lockdown addresses into the integrity_cfg map so the
# LSM programs can verify at runtime that module.sig_enforce has not
# been flipped. proc_t carries kallsyms (no dedicated type in
# selinux-policy 44.x); the read class is the only access required.
kernel_read_proc_files(lota_agent_t)

# /boot/vmlinuz-*
files_read_boot_files(lota_agent_t)
files_read_boot_symlinks(lota_agent_t)

# /sys
dev_read_sysfs(lota_agent_t)
# /sys/kernel/btf/vmlinux -- libbpf mmaps it during bpf_object__load to
# resolve CO-RE relocations against the running kernel; without the
# mmap class allow the load fails with -EINVAL at bpf_create_map_xattr.
dev_map_sysfs(lota_agent_t)

# /sys/firmware/efi/efivars
fs_read_efivarfs_files(lota_agent_t)

# /sys/fs/selinux
selinux_get_fs_mount(lota_agent_t)
selinux_compute_access_vector(lota_agent_t)

# dmesg
kernel_read_ring_buffer(lota_agent_t)

# /proc/cmdline
kernel_read_kernel_sysctls(lota_agent_t)

#
# Logging + IPC under systemd
#
# journal_init() in src/agent/journal.c routes lota_info/lota_warn/
# lota_err through sd_journal_send() whenever INVOCATION_ID is set
# (i.e. when systemd execs the agent). sd_journal_send() opens
# /run/systemd/journal/socket (syslogd_var_run_t). Without the
# logging_send_syslog_msg() rule below every diagnostic line the
# agent emits is silently dropped, so a startup that fails any
# downstream gate shows up in journalctl as exactly two stdout
# lines from test_iommu() with no context, and the operator has
# no way to attribute the failure.
#
# dbus_system_bus_client() grants connect+write on the system D-Bus
# socket (system_dbusd_var_run_t). The agent registers
# org.lota.Agent1 there for the policy reload + status RPC paths;
# without this rule dbus_init() succeeds (libdbus connects via
# autolaunch fallback) but every method dispatch is denied at the
# kernel and the verifier sees no D-Bus surface from inside the
# guest.
#
# pidfs_t arrived with kernel 6.9+ (Fedora 44 ships 6.19+). libsystemd
# 259 calls fstatfs() on the pidfd dirfd it opens internally during
# sd_listen_fds / sd_notify, so the agent must be able to getattr
# the pidfs root. No refpolicy interface exists yet, allow rule
# is explicit.
#
logging_send_syslog_msg(lota_agent_t)
logging_send_audit_msgs(lota_agent_t)

dbus_system_bus_client(lota_agent_t)

gen_require(`
	type pidfs_t;
')
allow lota_agent_t pidfs_t:filesystem getattr;

#
# Network
#

corenet_tcp_connect_http_port(lota_agent_t)
corenet_tcp_connect_http_cache_port(lota_agent_t)
sysnet_dns_name_resolve(lota_agent_t)

tunable_policy(`lota_network_attest',`
        allow lota_agent_t lota_port_t:tcp_socket name_connect;
        allow lota_agent_t self:tcp_socket create_stream_socket_perms;
        allow lota_agent_t self:udp_socket create_socket_perms;
        allow lota_agent_t self:netlink_route_socket { create bind getattr nlmsg_read };
')

#
# Module subsystem
#

tunable_policy(`lota_module_enforce',`
        modutils_read_module_deps(lota_agent_t)
')

#
# Misc
#

files_read_etc_files(lota_agent_t)
miscfiles_read_localization(lota_agent_t)
init_use_fds(lota_agent_t)
init_read_state(lota_agent_t)
files_pid_filetrans(lota_agent_t, lota_var_t, file, "lota-agent.pid")
